generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  HUB_MANAGER
  CONTENT_MANAGER  
  PROGRAM_OFFICER  
  QA_ADMIN_SUPPORT      //muadh 
}

enum ProgramType {
  TRAINING
  INCUBATION
  HACKATHON
  WORKSHOP
  FELLOWSHIP
  COMPETITION
  MENTORSHIP
  GRANT
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventType {
  WORKSHOP
  SEMINAR
  GUEST_LECTURE
  HACKATHON
  DEMO_DAY
  STARTUP_SHOWCASE
}

enum InquiryStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum AnnouncementCategory {
  FUNDING
  INTERNSHIP
  GRANT
  PARTNERSHIP
  CAMPUS_NEWS
  GENERAL
}

enum StartupStage {
  IDEA
  PROTOTYPE
  MVP
  GROWTH
  SCALING
}

// ============================================================
// USER (Admin System)
// SUPER_ADMIN -> hubId is null (system-wide access)
// All other roles -> hubId required (hub-scoped access)
// ============================================================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CONTENT_MANAGER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hub scope - null for SUPER_ADMIN only
  hubId String?
  hub   Hub?    @relation("HubStaff", fields: [hubId], references: [id])

  // Only populated for HUB_MANAGER
  managedHub Hub? @relation("HubManager")

  auditLogs    AuditLog[]
  authSessions AuthSession[]

  @@map("users")
}

// ============================================================
// HUB
// ============================================================

model Hub {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String
  focusArea    String
  location     String?
  contactEmail String?
  facilities   String[]
  gallery      String[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managerId String? @unique
  manager   User?   @relation("HubManager", fields: [managerId], references: [id])

  staff         User[]         @relation("HubStaff")
  programs      Program[]
  events        Event[]
  startups      Startup[]
  announcements Announcement[]

  @@map("hubs")
}

// ============================================================
// PROGRAM
// ============================================================

model Program {
  id            String      @id @default(uuid())
  title         String
  description   String
  type          ProgramType
  eligibility   String?
  maxApplicants Int?
  deadline      DateTime
  isActive      Boolean     @default(true)
  isPublished   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  hubId         String
  hub           Hub                   @relation(fields: [hubId], references: [id])
  registrations ProgramRegistration[]

  @@map("programs")
}

// ============================================================
// PROGRAM REGISTRATION
// Public users apply - no account needed.
// documents[] stores file URLs from cloud storage.
// ============================================================

model ProgramRegistration {
  id        String            @id @default(uuid())
  fullName  String
  email     String
  phone     String?
  status    ApplicationStatus @default(PENDING)
  documents String[]
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  programId String
  program   Program @relation(fields: [programId], references: [id])

  @@map("program_registrations")
}

// ============================================================
// EVENT
// hubId optional - null means system-wide BUK event
// ============================================================

model Event {
  id          String    @id @default(uuid())
  title       String
  description String
  type        EventType
  location    String?
  startDate   DateTime
  endDate     DateTime?
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  hubId         String?
  hub           Hub?                @relation(fields: [hubId], references: [id])
  registrations EventRegistration[]

  @@map("events")
}

// ============================================================
// EVENT REGISTRATION
// ============================================================

model EventRegistration {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  phone     String?
  createdAt DateTime @default(now())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  @@map("event_registrations")
}

// ============================================================
// STARTUP / INNOVATION SHOWCASE
// Submitted by public, approved by admins.
// ============================================================

model Startup {
  id          String       @id @default(uuid())
  name        String
  description String
  founderName String
  email       String?
  phone       String?
  stage       StartupStage @default(IDEA)
  isFeatured  Boolean      @default(false)
  isApproved  Boolean      @default(false)
  demoUrl     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  hubId String?
  hub   Hub?    @relation(fields: [hubId], references: [id])

  @@map("startups")
}

// ============================================================
// ANNOUNCEMENT / NEWS
// hubId optional - null means platform-wide announcement
// ============================================================

model Announcement {
  id          String               @id @default(uuid())
  title       String
  body        String
  category    AnnouncementCategory
  isPublished Boolean              @default(false)
  publishedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  hubId String?
  hub   Hub?    @relation(fields: [hubId], references: [id])

  @@map("announcements")
}

// ============================================================
// NEWSLETTER SUBSCRIBER
// ============================================================

model NewsletterSubscriber {
  id                String    @id @default(uuid())
  email             String    @unique
  isVerified        Boolean   @default(false)
  verificationToken String?
  verifiedAt        DateTime?
  subPrograms       Boolean   @default(true)
  subStartups       Boolean   @default(true)
  subEvents         Boolean   @default(true)
  subGrants         Boolean   @default(true)
  subInternships    Boolean   @default(true)
  subAnnouncements  Boolean   @default(true)
  createdAt         DateTime  @default(now())

  @@map("newsletter_subscribers")
}

// ============================================================
// CONTACT INQUIRY
// ============================================================

model ContactInquiry {
  id        String        @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String
  status    InquiryStatus @default(OPEN)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("contact_inquiries")
}

// ============================================================
// AUDIT LOG
// Tracks all admin actions - PRD non-functional requirement
// ============================================================

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model AuthSession {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}
